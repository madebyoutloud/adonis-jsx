{
  "name": "@outloud/adonis-jsx",
  "type": "module",
  "version": "1.0.0",
  "description": "JSX template support in AdonisJS 6/7.",
  "author": "Outloud <hello@outloud.co>",
  "contributors": [
    "Andrej Adamcik"
  ],
  "license": "MIT",
  "homepage": "https://github.com/madebyoutloud/adonis-jsx#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/madebyoutloud/adonis-jsx.git"
  },
  "files": [
    "build"
  ],
  "exports": {
    ".": "./build/src/index.js",
    "./provider": "./build/providers/jsx.provider.js",
    "./service": "./build/services/main.js"
  },
  "sideEffects": false,
  "scripts": {
    "copy:templates": "copyfiles \"stubs/**/*.stub\" build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . ",
    "lint:fix": "eslint --fix .",
    "pretest": "pnpm run lint",
    "test": "node --import=./tsnode.esm.js --enable-source-maps bin/test.ts",
    "build": "tsdown && pnpm run copy:templates",
    "release": "release-it",
    "playground": "cd playground && pnpm dev"
  },
  "peerDependencies": {
    "@adonisjs/core": "^6 || ^7",
    "@adonisjs/mail": "^10.2.0"
  },
  "peerDependenciesMeta": {
    "@adonisjs/mail": {
      "optional": true
    }
  },
  "devDependencies": {
    "@adonisjs/assembler": "^8.0.0",
    "@adonisjs/core": "~7.3.1",
    "@adonisjs/mail": "^10.2.0",
    "@adonisjs/tsconfig": "^1.4.1",
    "@outloud/eslint-config": "^2.1.3",
    "@swc/core": "^1.13.3",
    "@types/node": "^24.2.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "copyfiles": "^2.4.1",
    "eslint": "^9.33.0",
    "jsx-email": "^2.8.4",
    "reflect-metadata": "^0.2.2",
    "release-it": "^19.0.4",
    "tsdown": "0.21.8",
    "typescript": "~6.0.2"
  },
  "dependencies": {
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  }
}
